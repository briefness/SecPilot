# ============================================================
# SecPilot 环境变量配置示例
# 复制为 .env 后修改为实际值
# ============================================================

# ── 数据库 ──────────────────────────────────────────
DB_PASSWORD=secops_secure_pass_2024
DATABASE_URL=postgresql://secops:secops_secure_pass_2024@localhost:5434/secops_platform?schema=public

# ── Redis ────────────────────────────────────────────
REDIS_PASSWORD=secops_redis_pass_2024
REDIS_URL=redis://:secops_redis_pass_2024@localhost:6378/0

# ── 鉴权 ─────────────────────────────────────────────
# ⚠️  生产环境必须替换！至少 32 位随机字符串
JWT_SECRET=please_change_this_to_a_random_secret_at_least_32_chars

# 应用层敏感字段加密主密钥（AES-256-GCM）
# ⚠️  生产环境必须替换！64 位 hex 字符串
# 生成命令: openssl rand -hex 32
ENCRYPTION_MASTER_KEY=00112233445566778899aabbccddeeff00112233445566778899aabbccddeeff

# 流量染色盐值
TRAFFIC_DYE_SALT=change_me_to_a_random_salt_value

# 安全运营平台全局盐值（用于 token 哈希等）
# ⚠️  生产环境必须替换！至少 16 位随机字符串
SECOPS_SALT=change_this_to_a_random_salt_at_least_16_chars

# ── 端口 ─────────────────────────────────────────────
API_PORT=3000
WEB_PORT=8080

# ── 扫描器（可选，不配置则对应扫描器不启用） ──────────

# SonarQube
SONARQUBE_URL=http://localhost:9000
SONARQUBE_TOKEN=
SONARQUBE_DB_PASSWORD=sonarqube_pass_2024

# OWASP ZAP
ZAP_URL=http://localhost:8081
ZAP_API_KEY=zap_api_key_2024

# MobSF
MOBSF_URL=http://localhost:8000
MOBSF_API_KEY=mobsf_api_key_2024

# Nuclei / OSV（CLI 工具，填二进制路径）
NUCLEI_PATH=nuclei
OSV_SCANNER_PATH=osv-scanner

# ── DefectDojo（可选） ───────────────────────────────
DEFECTDOJO_URL=
DEFECTDOJO_API_KEY=

# ── 通知（可选） ─────────────────────────────────────
SLACK_WEBHOOK_URL=
PAGERDUTY_ROUTING_KEY=

# ── GitHub / GitLab 集成（可选） ─────────────────────
GITHUB_TOKEN=
GITLAB_TOKEN=
